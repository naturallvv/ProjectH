# ── 서버 ──
APP_ENV=development
CORS_ORIGINS=http://localhost:5173

# ── RAG 연동 (별도 팀원 서버) ──
# 비워 두면 백엔드가 mock 설명(fallback)을 반환한다.
RAG_SERVER_URL=
RAG_TIMEOUT_SECONDS=5

# ── 공공데이터 API 키 (Step 14 실연동) ──
# data.go.kr 에서 발급받은 "일반 인증키(Decoding)" 를 입력한다. 실제 키는 .env 에만 두고 커밋 금지.
KMA_API_KEY=
JDC_API_KEY=
DATA_GO_KR_API_KEY=

# JDC 면세점 매장정보 API 엔드포인트 (제공기관 공지에 따른 변경 후 URL, 복수형)
JDC_API_URL=https://apis.data.go.kr/B551391/jdcdutyfreeshops
PUBLIC_API_TIMEOUT_SECONDS=10
