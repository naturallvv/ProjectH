# ── 서버 ──
APP_ENV=development
CORS_ORIGINS=http://localhost:5173

# ── RAG 연동 (별도 팀원 서버) ──
# 비워 두면 백엔드가 mock 설명(fallback)을 반환한다.
RAG_SERVER_URL=
RAG_TIMEOUT_SECONDS=5
# 모델 가중치 로컬 경로(서버 기동용): scripts/preprocess/download_llm.py 로 다운로드
#   기본 저장 위치 /ceph_data/wq1880/barrierfree/models/kanana-1.5-8b-instruct-2505
RAG_MODEL_NAME=kakaocorp/kanana-1.5-8b-instruct-2505
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_VECTOR_STORE_DIR=../vector_store

# ── 공공데이터 API 키 (Step 14 실연동) ──
# data.go.kr 에서 발급받은 "일반 인증키(Decoding)" 를 입력한다. 실제 키는 .env 에만 두고 커밋 금지.
KMA_API_KEY=
JDC_API_KEY=
DATA_GO_KR_API_KEY=

# JDC 면세점 매장정보 API 엔드포인트 (제공기관 공지에 따른 변경 후 URL, 복수형)
JDC_API_URL=https://apis.data.go.kr/B551391/jdcdutyfreeshops
PUBLIC_API_TIMEOUT_SECONDS=10

# 카카오 모빌리티 길찾기 REST 키 (일정 실도로 경로용). 없으면 직선 동선.
KAKAO_REST_KEY=
